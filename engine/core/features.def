// The feature-flag manifest: the single source of truth for every flag.
//
// This file is intentionally header-guard-free and #included several times
// with REC_FEATURE redefined each time (the X-macro trick), so the enum, the
// table and the count can never drift apart. Editing this list is the only
// thing you do to add a flag.
//
//   REC_FEATURE(Id, "dotted.name", default_enabled)
//     Id              C++ identifier, reached as rec::FeatureId::k<Id>
//     "dotted.name"   stable string the REC_FEATURES env override matches on
//     default_enabled value before any override is applied
//
// A subsystem reads a flag with rec::FeatureEnabled(rec::FeatureId::k<Id>).

REC_FEATURE(PathTracer, "render.pathtracer", false)
REC_FEATURE(MeshShaderLod, "render.mesh_shader_lod", false)
REC_FEATURE(DistantLod, "render.distant_lod", true)
